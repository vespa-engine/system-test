<?xml version="1.0" encoding="utf-8" ?>
<services version="1.0">
  <admin version="2.0">
    <adminserver hostalias="node1"/>
  </admin>

  <container id="search" version="1.0">
    <nodes>
      <jvm options="-Xms16g -Xmx16g -Xlog:gc*=info:file=$VESPA_HOME/logs/vespa/gc.log:time,uptime,level,tags -Xlog:gc=info:stdout:time,uptime"
           gc-options="GC_OPTIONS_PLACEHOLDER" />
      <node hostalias='node1'/>
    </nodes>
    <search>
      <provider id="mock">
        <searcher id="com.yahoo.performance.searcher.GarbageGeneratingSearcher" bundle="performance"/>
      </provider>
    </search>
    <document-api/>
    <accesslog type="disabled"/>
  </container>

</services>
