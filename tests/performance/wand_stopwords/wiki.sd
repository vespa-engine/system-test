schema wiki {

  document wiki {
    # field myid type int {
    #   indexing: attribute | summary
    # }
    field title type string {
      indexing: index | summary
      index: enable-bm25
    }
    field text type string {
      indexing: index
      index: enable-bm25
    }
  }

  fieldset default {
    fields: title, text
  }

  rank-profile default {
    first-phase {
      expression: bm25(text)
    }
  }

}
